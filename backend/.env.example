# Server
PORT=5000

# MongoDB
# Local:      mongodb://127.0.0.1:27017/smart_attend
# Atlas:      mongodb+srv://<user>:<password>@cluster.mongodb.net/smart_attend
MONGO_URI=mongodb://127.0.0.1:27017/smart_attend

# JWT
# IMPORTANT: Change this to a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_strong_random_secret_here

# CORS (comma-separated list of allowed frontend origins)
# Leave empty to allow all origins in development
ALLOWED_ORIGINS=http://localhost:3000
